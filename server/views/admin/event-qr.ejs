<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>QR Code - HFNI Connect Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<div class="admin-layout">
  <%- include('./partials/sidebar', { currentPage: 'events' }) %>
  
  <main class="admin-main">
    <header class="admin-header">
      <h1 class="text-xl font-semibold">QR Code - <%= typeof event !== 'undefined' ? event.title : '' %></h1>
      <div class="text-sm text-secondary"><%= typeof staffName !== 'undefined' ? staffName : 'Admin' %></div>
    </header>
    
    <div class="admin-content">
      <div style="max-width: 32rem; margin: 0 auto;">
        <div class="card">
          <div class="card-header text-center">
            <h3><%= typeof event !== 'undefined' ? event.title : '' %></h3>
            <p class="text-secondary text-sm mt-1"><%= typeof event !== 'undefined' && event.eventDate ? new Date(event.eventDate).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : '' %></p>
          </div>
          <div class="card-body text-center">
            <div class="qr-code-container">
              <img src="<%= typeof qrCodeUrl !== 'undefined' ? qrCodeUrl : '' %>" alt="QR Code for attendance" data-testid="img-qr-code">
              <p class="text-sm text-secondary mt-4">Scan this QR code to mark attendance</p>
            </div>
            
            <div class="mt-4 p-4" style="background: var(--bg); border-radius: var(--radius);">
              <p class="text-xs text-secondary mb-2">Or share this link:</p>
              <input type="text" class="form-control text-sm" value="<%= typeof attendanceUrl !== 'undefined' ? attendanceUrl : '' %>" readonly onclick="this.select()" data-testid="input-attendance-url">
            </div>
          </div>
          <div class="card-footer">
            <div class="flex justify-between gap-4 mb-3">
              <a href="/admin/events" class="btn btn-secondary" data-testid="button-back">Back to Events</a>
              <a href="/admin/events/<%= typeof event !== 'undefined' ? event.id : '' %>/report" class="btn btn-ghost" data-testid="button-view-report">View Report</a>
            </div>
            <form method="POST" action="/admin/events/<%= typeof event !== 'undefined' ? event.id : '' %>/close">
              <div class="form-group mb-3">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="sendFollowup" value="1" class="form-checkbox" data-testid="checkbox-send-followup">
                  <span class="text-sm">Send absentee follow-up SMS now</span>
                </label>
              </div>
              <button type="submit" class="btn btn-danger btn-block" data-testid="button-close-attendance">Close Attendance</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
</body>
</html>
