<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Send Notification - HFNI Connect Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<div class="admin-layout">
  <%- include('./partials/sidebar', { currentPage: 'notifications' }) %>
  
  <main class="admin-main">
    <header class="admin-header">
      <h1 class="text-xl font-semibold">Send Notification</h1>
      <div class="text-sm text-secondary"><%= typeof staffName !== 'undefined' ? staffName : 'Admin' %></div>
    </header>
    
    <div class="admin-content">
      <div class="card" style="max-width: 40rem;">
        <div class="card-body">
          <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-error"><%= error %></div>
          <% } %>
          
          <form method="POST" action="/admin/notifications/new">
            <div class="form-group">
              <label class="form-label" for="title">Title *</label>
              <input type="text" id="title" name="title" class="form-control" required data-testid="input-title">
            </div>
            
            <div class="form-group">
              <label class="form-label" for="body">Message *</label>
              <textarea id="body" name="body" class="form-control" rows="4" required data-testid="input-body"></textarea>
            </div>
            
            <div class="form-group">
              <label class="form-label" for="type">Type</label>
              <select id="type" name="type" class="form-control" data-testid="select-type">
                <option value="general">General</option>
                <option value="meeting_reminder">Meeting Reminder</option>
                <option value="prayer_update">Prayer Update</option>
                <option value="urgent_announcement">Urgent Announcement</option>
              </select>
            </div>
            
            <div class="flex gap-3 mt-6">
              <a href="/admin/notifications" class="btn btn-secondary" data-testid="button-cancel">Cancel</a>
              <button type="submit" class="btn btn-primary flex-1" data-testid="button-submit">Send Notification</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </main>
</div>
</body>
</html>
