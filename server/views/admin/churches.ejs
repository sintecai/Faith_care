<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Churches - HFNI Connect Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<div class="admin-layout">
  <%- include('./partials/sidebar', { currentPage: 'churches' }) %>
  
  <main class="admin-main">
    <header class="admin-header">
      <h1 class="text-xl font-semibold">Churches</h1>
      <div class="text-sm text-secondary"><%= typeof staffName !== 'undefined' ? staffName : 'Admin' %></div>
    </header>
    
    <div class="admin-content">
      <div class="flex justify-between items-center gap-4 mb-6">
        <div></div>
        <a href="/admin/churches/new" class="btn btn-primary" data-testid="button-add-church">Add Church</a>
      </div>
      
      <% if (typeof message !== 'undefined' && message) { %>
        <div class="alert alert-success"><%= message %></div>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      
      <% if (typeof churches === 'undefined' || churches.length === 0) { %>
        <div class="empty-state">
          <svg class="empty-state-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 2L2 7v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V7L12 2z"/>
          </svg>
          <p>No churches found</p>
          <a href="/admin/churches/new" class="btn btn-primary mt-4">Add First Church</a>
        </div>
      <% } else { %>
        <div class="table-container">
          <table class="data-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Address</th>
                <th>Phone</th>
                <th>Email</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% churches.forEach(function(c) { %>
              <tr data-testid="row-church-<%= c.id %>">
                <td><%= c.name %></td>
                <td><%= c.address || '-' %></td>
                <td><%= c.phone || '-' %></td>
                <td><%= c.email || '-' %></td>
                <td>
                  <div class="flex gap-2">
                    <a href="/admin/churches/<%= c.id %>/edit" class="btn btn-secondary btn-sm" data-testid="button-edit-<%= c.id %>">Edit</a>
                    <form method="POST" action="/admin/churches/<%= c.id %>/delete" onsubmit="return confirm('Are you sure you want to delete this church?');">
                      <button type="submit" class="btn btn-danger btn-sm" data-testid="button-delete-<%= c.id %>">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </main>
</div>
</body>
</html>
