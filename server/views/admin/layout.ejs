<% const currentPg = typeof currentPage !== 'undefined' ? currentPage : ''; %>
<% const pageTtl = typeof pageTitle !== 'undefined' ? pageTitle : 'Dashboard'; %>
<% const staffNm = typeof staffName !== 'undefined' ? staffName : 'Admin'; %>
<% const contentHtml = typeof content !== 'undefined' ? content : ''; %>

<%- include('../layouts/main', { content: `
<div class="admin-layout">
  <aside class="admin-sidebar">
    <div class="admin-sidebar-header">
      <a href="/admin/dashboard" class="admin-sidebar-logo" data-testid="link-admin-home">HFNI Connect</a>
    </div>
    
    <nav class="admin-sidebar-nav">
      <a href="/admin/dashboard" class="admin-nav-item ${currentPg === 'dashboard' ? 'active' : ''}" data-testid="nav-dashboard">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="3" width="7" height="7"/>
          <rect x="14" y="3" width="7" height="7"/>
          <rect x="14" y="14" width="7" height="7"/>
          <rect x="3" y="14" width="7" height="7"/>
        </svg>
        Dashboard
      </a>
      
      <a href="/admin/members" class="admin-nav-item ${currentPg === 'members' ? 'active' : ''}" data-testid="nav-members">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        Members
      </a>
      
      <a href="/admin/events" class="admin-nav-item ${currentPg === 'events' ? 'active' : ''}" data-testid="nav-events">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        Mass Events
      </a>
      
      <a href="/admin/prayers" class="admin-nav-item ${currentPg === 'prayers' ? 'active' : ''}" data-testid="nav-prayers">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
          <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
        </svg>
        Prayer Requests
      </a>
      
      <a href="/admin/dues" class="admin-nav-item ${currentPg === 'dues' ? 'active' : ''}" data-testid="nav-dues">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="12" y1="1" x2="12" y2="23"/>
          <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
        </svg>
        Dues
      </a>
    </nav>
    
    <div class="admin-sidebar-footer">
      <a href="/admin/logout" class="admin-nav-item" data-testid="button-admin-logout">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
          <polyline points="16 17 21 12 16 7"/>
          <line x1="21" y1="12" x2="9" y2="12"/>
        </svg>
        Logout
      </a>
    </div>
  </aside>
  
  <main class="admin-main">
    <header class="admin-header">
      <h1 class="text-xl font-semibold">${pageTtl}</h1>
      <div class="text-sm text-secondary">${staffNm}</div>
    </header>
    
    <div class="admin-content">
      ${contentHtml}
    </div>
  </main>
</div>
` }) %>
