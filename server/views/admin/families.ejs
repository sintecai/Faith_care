<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Families - HFNI Connect Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<div class="admin-layout">
  <%- include('./partials/sidebar', { currentPage: 'families' }) %>
  
  <main class="admin-main">
    <header class="admin-header">
      <h1 class="text-xl font-semibold">Families</h1>
      <div class="text-sm text-secondary"><%= typeof staffName !== 'undefined' ? staffName : 'Admin' %></div>
    </header>
    
    <div class="admin-content">
      <div class="flex justify-between items-center gap-4 mb-6">
        <div></div>
        <a href="/admin/families/new" class="btn btn-primary" data-testid="button-add-family">Add Family</a>
      </div>
      
      <% if (typeof message !== 'undefined' && message) { %>
        <div class="alert alert-success"><%= message %></div>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      
      <% if (typeof families === 'undefined' || families.length === 0) { %>
        <div class="empty-state">
          <svg class="empty-state-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          <p>No families found</p>
          <a href="/admin/families/new" class="btn btn-primary mt-4">Add First Family</a>
        </div>
      <% } else { %>
        <div class="table-container">
          <table class="data-table">
            <thead>
              <tr>
                <th>Family Name</th>
                <th>Contact Phone</th>
                <th>Address</th>
                <th>Due Amount</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% families.forEach(function(f) { %>
              <%
                // Build compact address string with fallback to legacy address field
                let addressParts = [];
                if (f.addressLine1) addressParts.push(f.addressLine1);
                if (f.city) addressParts.push(f.city);
                if (f.postcode) addressParts.push(f.postcode);
                let displayAddress = addressParts.join(', ');
                // Fallback to legacy address field if structured fields are empty
                if (!displayAddress && f.address) displayAddress = f.address;
              %>
              <tr data-testid="row-family-<%= f.id %>">
                <td><%= f.name %></td>
                <td><%= f.contactPhone || '-' %></td>
                <td><%= displayAddress || '-' %></td>
                <td><%= f.dueAmount ? '£' + f.dueAmount : '-' %></td>
                <td>
                  <div class="flex gap-2">
                    <a href="/admin/families/<%= f.id %>/edit" class="btn btn-secondary btn-sm" data-testid="button-edit-<%= f.id %>">Edit</a>
                    <form method="POST" action="/admin/families/<%= f.id %>/delete" onsubmit="return confirm('Are you sure you want to delete this family?');">
                      <button type="submit" class="btn btn-danger btn-sm" data-testid="button-delete-<%= f.id %>">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </main>
</div>
</body>
</html>
