<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= isEdit ? 'Edit' : 'New' %> Announcement - HFNI Connect Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<div class="admin-layout">
  <%- include('./partials/sidebar', { currentPage: 'announcements' }) %>
  
  <main class="admin-main">
    <header class="admin-header">
      <h1 class="text-xl font-semibold"><%= isEdit ? 'Edit' : 'New' %> Announcement</h1>
      <div class="text-sm text-secondary"><%= typeof staffName !== 'undefined' ? staffName : 'Admin' %></div>
    </header>
    
    <div class="admin-content">
      <div class="card" style="max-width: 40rem;">
        <div class="card-body">
          <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-error"><%= error %></div>
          <% } %>
          
          <form method="POST" action="/admin/announcements<%= isEdit ? '/' + announcement.id + '/edit' : '/new' %>">
            <div class="form-group">
              <label class="form-label" for="title">Title *</label>
              <input type="text" id="title" name="title" class="form-control" value="<%= (typeof announcement !== 'undefined' && announcement) ? announcement.title : '' %>" required data-testid="input-title">
            </div>
            
            <div class="form-group">
              <label class="form-label" for="body">Message *</label>
              <textarea id="body" name="body" class="form-control" rows="5" required data-testid="input-body"><%= (typeof announcement !== 'undefined' && announcement) ? announcement.body : '' %></textarea>
            </div>
            
            <div class="form-group">
              <label class="form-label" for="priority">Priority</label>
              <select id="priority" name="priority" class="form-control" data-testid="select-priority">
                <option value="normal" <%= (typeof announcement !== 'undefined' && announcement && announcement.priority === 'normal') ? 'selected' : '' %>>Normal</option>
                <option value="urgent" <%= (typeof announcement !== 'undefined' && announcement && announcement.priority === 'urgent') ? 'selected' : '' %>>Urgent</option>
              </select>
            </div>
            
            <% if (!isEdit) { %>
            <div class="form-group">
              <label class="form-label-checkbox">
                <input type="checkbox" name="sendNotifications" value="on" checked data-testid="checkbox-send-notifications">
                Notify all members in-app
              </label>
              <p class="form-hint">Members will see this announcement in their notifications</p>
            </div>
            <% } %>
            
            <div class="flex gap-3 mt-6">
              <a href="/admin/announcements" class="btn btn-secondary" data-testid="button-cancel">Cancel</a>
              <button type="submit" class="btn btn-primary flex-1" data-testid="button-submit"><%= isEdit ? 'Update' : 'Create' %> Announcement</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </main>
</div>
</body>
</html>
