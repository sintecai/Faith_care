<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Prayer Cells - HFNI Connect Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<div class="admin-layout">
  <%- include('./partials/sidebar', { currentPage: 'units' }) %>
  
  <main class="admin-main">
    <header class="admin-header">
      <h1 class="text-xl font-semibold">Prayer Cells</h1>
      <div class="text-sm text-secondary"><%= typeof staffName !== 'undefined' ? staffName : 'Admin' %></div>
    </header>
    
    <div class="admin-content">
      <div class="flex justify-between items-center gap-4 mb-6 flex-wrap">
        <div class="flex gap-2">
          <a href="/admin/units" class="btn <%= currentFilter === 'active' ? 'btn-primary' : 'btn-secondary' %> btn-sm" data-testid="filter-active">Active</a>
          <a href="/admin/units?show=archived" class="btn <%= currentFilter === 'archived' ? 'btn-primary' : 'btn-secondary' %> btn-sm" data-testid="filter-archived">Archived</a>
          <a href="/admin/units?show=all" class="btn <%= currentFilter === 'all' ? 'btn-primary' : 'btn-secondary' %> btn-sm" data-testid="filter-all">All</a>
        </div>
        <a href="/admin/units/new" class="btn btn-primary" data-testid="button-add-unit">Add Prayer Cell</a>
      </div>
      
      <% if (typeof message !== 'undefined' && message) { %>
        <div class="alert alert-success"><%= message %></div>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      
      <% if (typeof units === 'undefined' || units.length === 0) { %>
        <div class="empty-state">
          <svg class="empty-state-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="10"/>
            <path d="M14.31 8l5.74 9.94M9.69 8h11.48M7.38 12l5.74-9.94M9.69 16L3.95 6.06M14.31 16H2.83M16.62 12l-5.74 9.94"/>
          </svg>
          <p>No <%= currentFilter === 'archived' ? 'archived ' : currentFilter === 'all' ? '' : 'active ' %>prayer cells found</p>
          <% if (currentFilter === 'active') { %>
            <a href="/admin/units/new" class="btn btn-primary mt-4">Add First Prayer Cell</a>
          <% } %>
        </div>
      <% } else { %>
        <div class="table-container">
          <table class="data-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Members</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% units.forEach(function(u) { %>
              <tr data-testid="row-unit-<%= u.id %>">
                <td><%= u.name %></td>
                <td><%= u.description || '-' %></td>
                <td><%= u.memberCount %></td>
                <td>
                  <% if (u.isActive) { %>
                    <span class="badge badge-success" data-testid="badge-active-<%= u.id %>">Active</span>
                  <% } else { %>
                    <span class="badge badge-secondary" data-testid="badge-archived-<%= u.id %>">Archived</span>
                  <% } %>
                </td>
                <td>
                  <div class="flex gap-2 flex-wrap">
                    <a href="/admin/units/<%= u.id %>/edit" class="btn btn-secondary btn-sm" data-testid="button-edit-<%= u.id %>">Edit</a>
                    <% if (u.isActive) { %>
                      <form method="POST" action="/admin/units/<%= u.id %>/archive" onsubmit="return confirm('Are you sure you want to archive this prayer cell?');">
                        <button type="submit" class="btn btn-warning btn-sm" data-testid="button-archive-<%= u.id %>">Archive</button>
                      </form>
                    <% } else { %>
                      <form method="POST" action="/admin/units/<%= u.id %>/restore">
                        <button type="submit" class="btn btn-success btn-sm" data-testid="button-restore-<%= u.id %>">Restore</button>
                      </form>
                    <% } %>
                  </div>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </main>
</div>
</body>
</html>
