<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New Volunteer Request - HFNI Connect Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<div class="admin-layout">
  <%- include('./partials/sidebar', { currentPage: 'volunteer' }) %>
  
  <main class="admin-main">
    <header class="admin-header">
      <h1 class="text-xl font-semibold">New Volunteer Request</h1>
      <div class="text-sm text-secondary"><%= typeof staffName !== 'undefined' ? staffName : 'Admin' %></div>
    </header>
    
    <div class="admin-content">
      <div class="card" style="max-width: 40rem;">
        <div class="card-body">
          <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-error"><%= error %></div>
          <% } %>
          
          <form method="POST" action="/admin/volunteer/new">
            <div class="form-group">
              <label class="form-label" for="title">Title *</label>
              <input type="text" id="title" name="title" class="form-control" placeholder="e.g., Sunday Setup Team" required data-testid="input-title">
            </div>
            
            <div class="form-group">
              <label class="form-label" for="description">Description</label>
              <textarea id="description" name="description" class="form-control" rows="3" placeholder="Describe what volunteers will be doing..." data-testid="input-description"></textarea>
            </div>
            
            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="eventDate">Event Date</label>
                <input type="date" id="eventDate" name="eventDate" class="form-control" data-testid="input-event-date">
              </div>
              
              <div class="form-group">
                <label class="form-label" for="requiredVolunteers">Volunteers Needed</label>
                <input type="number" id="requiredVolunteers" name="requiredVolunteers" class="form-control" min="1" value="1" data-testid="input-required">
              </div>
            </div>
            
            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="startTime">Start Time</label>
                <input type="time" id="startTime" name="startTime" class="form-control" data-testid="input-start-time">
              </div>
              
              <div class="form-group">
                <label class="form-label" for="endTime">End Time</label>
                <input type="time" id="endTime" name="endTime" class="form-control" data-testid="input-end-time">
              </div>
            </div>
            
            <div class="form-group">
              <label class="form-label" for="location">Location</label>
              <input type="text" id="location" name="location" class="form-control" placeholder="Where will they serve?" data-testid="input-location">
            </div>
            
            <div class="flex gap-3 mt-6">
              <a href="/admin/volunteer" class="btn btn-secondary" data-testid="button-cancel">Cancel</a>
              <button type="submit" class="btn btn-primary flex-1" data-testid="button-submit">Create Request</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </main>
</div>
<style>.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }</style>
</body>
</html>
