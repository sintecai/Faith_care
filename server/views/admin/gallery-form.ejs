<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Gallery Item - HFNI Connect Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<div class="admin-layout">
  <%- include('./partials/sidebar', { currentPage: 'gallery' }) %>
  
  <main class="admin-main">
    <header class="admin-header">
      <h1 class="text-xl font-semibold">Add Gallery Item</h1>
      <div class="text-sm text-secondary"><%= typeof staffName !== 'undefined' ? staffName : 'Admin' %></div>
    </header>
    
    <div class="admin-content">
      <div class="card" style="max-width: 40rem;">
        <div class="card-body">
          <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-error"><%= error %></div>
          <% } %>
          
          <form method="POST" action="/admin/gallery/new" enctype="multipart/form-data">
            <div class="form-group">
              <label class="form-label" for="title">Title *</label>
              <input type="text" id="title" name="title" class="form-control" required data-testid="input-title">
            </div>
            
            <div class="form-group">
              <label class="form-label" for="imageFile">Upload Image</label>
              <input type="file" id="imageFile" name="imageFile" class="form-control" accept="image/png,image/jpeg,image/jpg,image/webp" data-testid="input-file">
              <p class="form-hint">Max 5MB. Supported: PNG, JPG, JPEG, WebP</p>
            </div>
            
            <div class="form-group">
              <label class="form-label" for="url">Or Image/Video URL</label>
              <input type="url" id="url" name="url" class="form-control" placeholder="https://..." data-testid="input-url">
              <p class="form-hint">If you upload a file, this URL will be ignored</p>
            </div>
            
            <div class="form-group">
              <label class="form-label" for="mediaType">Media Type</label>
              <select id="mediaType" name="mediaType" class="form-control" data-testid="select-media-type">
                <option value="photo">Photo</option>
                <option value="video">Video</option>
              </select>
            </div>
            
            <div class="form-group">
              <label class="form-label" for="category">Category</label>
              <select id="category" name="category" class="form-control" data-testid="select-category">
                <option value="general">General</option>
                <option value="tnt">TNT</option>
                <option value="jesus_school">Jesus School</option>
                <option value="core_leaders">Core Leaders</option>
                <option value="outreach">Outreach</option>
              </select>
            </div>
            
            <div class="flex gap-3 mt-6">
              <a href="/admin/gallery" class="btn btn-secondary" data-testid="button-cancel">Cancel</a>
              <button type="submit" class="btn btn-primary flex-1" data-testid="button-submit">Add to Gallery</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </main>
</div>
</body>
</html>
