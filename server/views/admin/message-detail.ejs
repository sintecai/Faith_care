<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= conversation.subject %> - Messages - HFNI Connect Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .message-thread { display: flex; flex-direction: column; gap: 1rem; max-height: 50vh; overflow-y: auto; padding: 1rem; background: var(--muted); border-radius: 8px; }
    .message-bubble { padding: 0.75rem 1rem; border-radius: 12px; max-width: 85%; }
    .message-bubble.admin { background: var(--primary); color: white; align-self: flex-end; border-bottom-right-radius: 4px; }
    .message-bubble.member { background: var(--card-bg); border: 1px solid var(--border); align-self: flex-start; border-bottom-left-radius: 4px; }
    .message-meta { font-size: 0.75rem; opacity: 0.7; margin-top: 0.25rem; }
    .conversation-info { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 1rem; }
    .conversation-info .info-item { display: flex; flex-direction: column; }
    .conversation-info .info-label { font-size: 0.75rem; color: var(--text-secondary); }
    .conversation-info .info-value { font-weight: 500; }
  </style>
</head>
<body>
<div class="admin-layout">
  <%- include('./partials/sidebar', { currentPage: 'messages' }) %>
  
  <main class="admin-main">
    <header class="admin-header">
      <div class="flex items-center gap-3 flex-wrap">
        <a href="/admin/messages" class="btn btn-ghost btn-sm" data-testid="button-back">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          Back
        </a>
        <h1 class="text-xl font-semibold"><%= conversation.subject %></h1>
      </div>
      <div class="flex items-center gap-3">
        <span class="badge <%= conversation.status === 'open' ? 'badge-success' : 'badge-secondary' %>"><%= conversation.status === 'open' ? 'Open' : 'Closed' %></span>
        <% if (conversation.status === 'open') { %>
          <form method="POST" action="/admin/messages/<%= conversation.id %>/close" style="display:inline;">
            <button type="submit" class="btn btn-secondary btn-sm" data-testid="button-close">Close Conversation</button>
          </form>
        <% } else { %>
          <form method="POST" action="/admin/messages/<%= conversation.id %>/reopen" style="display:inline;">
            <button type="submit" class="btn btn-primary btn-sm" data-testid="button-reopen">Reopen</button>
          </form>
        <% } %>
      </div>
    </header>
    
    <div class="admin-content">
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error mb-4"><%= error %></div>
      <% } %>
      
      <div class="conversation-info">
        <div class="info-item">
          <span class="info-label">Member</span>
          <span class="info-value" data-testid="text-member-name"><%= memberName || 'Unknown' %></span>
        </div>
        <div class="info-item">
          <span class="info-label">Started</span>
          <span class="info-value"><%= conversation.createdAt ? new Date(conversation.createdAt).toLocaleString('en-GB') : '-' %></span>
        </div>
      </div>
      
      <div class="message-thread mb-4">
        <% if (typeof messages !== 'undefined' && messages.length > 0) { %>
          <% messages.forEach(function(msg) { %>
            <div class="message-bubble <%= msg.senderType %>" data-testid="message-<%= msg.id %>">
              <div><%= msg.body %></div>
              <div class="message-meta">
                <strong><%= msg.senderName || (msg.senderType === 'admin' ? 'Staff' : 'Member') %></strong> -
                <%= new Date(msg.createdAt || Date.now()).toLocaleString('en-GB', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %>
              </div>
            </div>
          <% }); %>
        <% } else { %>
          <div class="text-center text-muted py-4">No messages yet.</div>
        <% } %>
      </div>
      
      <% if (conversation.status === 'open') { %>
        <div class="card">
          <div class="card-header">
            <h3 class="font-semibold">Reply to Member</h3>
          </div>
          <div class="card-body">
            <form method="POST" action="/admin/messages/<%= conversation.id %>/reply" data-testid="form-reply">
              <div class="form-group mb-3">
                <textarea name="body" class="form-control" rows="3" required placeholder="Type your response..." data-testid="input-reply"></textarea>
              </div>
              <button type="submit" class="btn btn-primary" data-testid="button-send-reply">Send Reply</button>
            </form>
          </div>
        </div>
      <% } else { %>
        <div class="text-center text-muted py-4">
          This conversation is closed. 
          <form method="POST" action="/admin/messages/<%= conversation.id %>/reopen" style="display:inline;">
            <button type="submit" class="link" style="background:none; border:none; cursor:pointer;">Reopen</button>
          </form> 
          to continue messaging.
        </div>
      <% } %>
    </div>
  </main>
</div>
</body>
</html>
