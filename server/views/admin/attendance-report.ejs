<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Attendance Report - HFNI Connect Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<div class="admin-layout">
  <%- include('./partials/sidebar', { currentPage: 'events' }) %>
  
  <main class="admin-main">
    <header class="admin-header">
      <h1 class="text-xl font-semibold">Attendance Report</h1>
      <div class="text-sm text-secondary"><%= typeof staffName !== 'undefined' ? staffName : 'Admin' %></div>
    </header>
    
    <div class="admin-content">
      <div class="mb-6">
        <a href="/admin/events" class="btn btn-ghost" data-testid="button-back">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          Back to Meetings
        </a>
      </div>
      
      <% if (typeof message !== 'undefined' && message) { %>
        <div class="alert alert-success mb-4"><%= message %></div>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error mb-4"><%= error %></div>
      <% } %>
      
      <div class="card mb-6">
        <div class="card-header">
          <h3><%= typeof event !== 'undefined' ? event.title : 'Meeting' %></h3>
          <p class="text-secondary text-sm mt-1">
            <%= typeof event !== 'undefined' && event.eventDate ? new Date(event.eventDate).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : '' %>
          </p>
        </div>
        <div class="card-body">
          <div class="flex gap-6 flex-wrap">
            <div class="stat-item">
              <div class="stat-value text-success" data-testid="text-attended-count"><%= typeof attendees !== 'undefined' ? attendees.length : 0 %></div>
              <div class="stat-label">Attended</div>
            </div>
            <div class="stat-item">
              <div class="stat-value text-warning" data-testid="text-absent-count"><%= typeof absentees !== 'undefined' ? absentees.length : 0 %></div>
              <div class="stat-label">Absent (with SMS consent)</div>
            </div>
          </div>
        </div>
      </div>
      
      <% if (typeof absentees !== 'undefined' && absentees.length > 0) { %>
      <div class="card mb-6">
        <div class="card-header">
          <h3>Follow-up Messages</h3>
          <p class="text-secondary text-sm mt-1">Send caring messages to members who missed this meeting</p>
        </div>
        <div class="card-body">
          <div class="form-group">
            <label class="form-label" for="templateKey">Follow-up message</label>
            <select id="templateKey" name="templateKey" class="form-control" data-testid="select-template">
              <% if (typeof templates !== 'undefined') { %>
                <% templates.forEach(function(t, index) { %>
                  <option value="<%= t.key %>" <%= index === 0 ? 'selected' : '' %>><%= t.preview %></option>
                <% }); %>
              <% } %>
            </select>
            <p class="form-hint">Select a caring message to send to absentees</p>
          </div>
          
          <div class="flex gap-3 flex-wrap">
            <form method="POST" action="/admin/events/<%= event.id %>/send-followup" data-testid="form-send-followup" style="display:inline;">
              <input type="hidden" name="templateKey" id="sendTemplateKey" value="">
              <button type="submit" class="btn btn-primary" data-testid="button-send-now">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/>
                </svg>
                Send Follow-up Now (<%= absentees.length %>)
              </button>
            </form>
            
            <form method="POST" action="/admin/events/<%= event.id %>/queue-followup" data-testid="form-queue-followup" style="display:inline;">
              <input type="hidden" name="templateKey" id="queueTemplateKey" value="">
              <button type="submit" class="btn btn-secondary" data-testid="button-queue-messages">
                Queue for Later (<%= absentees.length %>)
              </button>
            </form>
          </div>
          
          <script>
            // Sync template selection to hidden inputs
            document.getElementById('templateKey').addEventListener('change', function() {
              document.getElementById('sendTemplateKey').value = this.value;
              document.getElementById('queueTemplateKey').value = this.value;
            });
            // Initialize on page load
            document.addEventListener('DOMContentLoaded', function() {
              var sel = document.getElementById('templateKey');
              document.getElementById('sendTemplateKey').value = sel.value;
              document.getElementById('queueTemplateKey').value = sel.value;
            });
          </script>
        </div>
      </div>
      <% } %>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="card">
          <div class="card-header">
            <h3>Attendees (<%= typeof attendees !== 'undefined' ? attendees.length : 0 %>)</h3>
          </div>
          <div class="card-body p-0">
            <% if (typeof attendees === 'undefined' || attendees.length === 0) { %>
              <p class="text-center text-secondary py-6">No attendees recorded</p>
            <% } else { %>
              <div class="table-container">
                <table>
                  <thead>
                    <tr>
                      <th>Name</th>
                      <th>Phone</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% attendees.forEach(function(m) { %>
                    <tr data-testid="row-attendee-<%= m.id %>">
                      <td class="font-medium"><%= m.firstName %> <%= m.lastName %></td>
                      <td class="text-secondary"><%= m.phone || '-' %></td>
                    </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </div>
        </div>
        
        <div class="card">
          <div class="card-header">
            <h3>Absentees with SMS Consent (<%= typeof absentees !== 'undefined' ? absentees.length : 0 %>)</h3>
          </div>
          <div class="card-body p-0">
            <% if (typeof absentees === 'undefined' || absentees.length === 0) { %>
              <p class="text-center text-secondary py-6">No absentees with SMS consent</p>
            <% } else { %>
              <div class="table-container">
                <table>
                  <thead>
                    <tr>
                      <th>Name</th>
                      <th>Phone</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% absentees.forEach(function(m) { %>
                    <tr data-testid="row-absentee-<%= m.id %>">
                      <td class="font-medium"><%= m.firstName %> <%= m.lastName %></td>
                      <td class="text-secondary"><%= m.phone || '-' %></td>
                    </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
</body>
</html>
