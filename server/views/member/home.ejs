<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Home - HFNI Connect</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    /* Override hfni-themed background with new image - use high specificity */
    .member-page.hfni-themed.member-page-bg {
      background: url('/images/member-bg.jpg') center center / cover no-repeat fixed !important;
      position: relative;
      min-height: 100vh;
    }
    /* Dark overlay - override white overlay from styles.css */
    .member-page.hfni-themed.member-page-bg::before {
      content: '' !important;
      position: fixed !important;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.35) !important;
      z-index: 0 !important;
      pointer-events: none;
    }
    /* Content above overlay */
    .member-page.hfni-themed.member-page-bg .member-header,
    .member-page.hfni-themed.member-page-bg .member-content {
      position: relative;
      z-index: 1;
    }
    /* Header - transparent, not white */
    .member-page.hfni-themed.member-page-bg .member-header {
      background: transparent !important;
      backdrop-filter: none !important;
      -webkit-backdrop-filter: none !important;
    }
    .member-page.hfni-themed.member-page-bg .member-header .member-logo {
      color: #ffffff !important;
    }
    .member-page.hfni-themed.member-page-bg .member-header .member-name {
      color: rgba(255, 255, 255, 0.9) !important;
    }
    /* Dashboard - transparent, not white glass */
    .member-page.hfni-themed.member-page-bg .member-content .member-dashboard {
      background: transparent !important;
      backdrop-filter: none !important;
      -webkit-backdrop-filter: none !important;
      box-shadow: none !important;
    }
    /* Welcome text - pure white, bold, with shadow */
    .member-page.hfni-themed.member-page-bg .member-welcome h1 {
      color: #ffffff !important;
      font-weight: 700 !important;
      text-shadow: 0 2px 8px rgba(0, 0, 0, 0.7) !important;
    }
    .member-page.hfni-themed.member-page-bg .member-welcome .subtitle {
      color: rgba(255, 255, 255, 0.92) !important;
      text-shadow: 0 1px 6px rgba(0, 0, 0, 0.6) !important;
    }
    /* Section headers - white */
    .member-page.hfni-themed.member-page-bg .dashboard-section-header {
      color: #ffffff !important;
    }
    .member-page.hfni-themed.member-page-bg .dashboard-section-header h2 {
      color: #ffffff !important;
      font-weight: 700 !important;
      text-shadow: 0 2px 8px rgba(0, 0, 0, 0.7) !important;
    }
    .member-page.hfni-themed.member-page-bg .dashboard-section-header svg {
      stroke: #ffffff !important;
    }
    /* Cards - solid white, floating */
    .member-page.hfni-themed.member-page-bg .dashboard-tile {
      background: #ffffff !important;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.18) !important;
    }
    .member-page.hfni-themed.member-page-bg .dashboard-tile:hover {
      transform: translateY(-3px);
      box-shadow: 0 14px 40px rgba(0, 0, 0, 0.22) !important;
    }
    .member-page.hfni-themed.member-page-bg .dashboard-tile.disabled {
      background: #ffffff !important;
      opacity: 0.85;
    }
    .member-page.hfni-themed.member-page-bg .upcoming-event-card {
      background: #ffffff !important;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.18) !important;
    }
    .member-page.hfni-themed.member-page-bg .alert {
      background: #ffffff !important;
    }
    /* Mobile: disable fixed for performance */
    @media (max-width: 768px) {
      .member-page.hfni-themed.member-page-bg {
        background-attachment: scroll !important;
      }
      .member-page.hfni-themed.member-page-bg::before {
        position: absolute !important;
      }
    }
  </style>
</head>
<body>
<div class="member-page hfni-themed member-page-bg">
  <!-- Mobile Navigation -->
  <%- include('../partials/member-mobile-nav') %>
  
  <div class="member-header">
    <div class="member-header-inner">
      <!-- Mobile hamburger button -->
      <button id="mobile-menu-btn" class="mobile-menu-btn" data-testid="button-mobile-menu" aria-label="Open menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
      
      <a href="/home" class="member-logo" data-testid="link-home">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2L2 7v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V7L12 2z"/>
          <path d="M12 7v8"/>
        </svg>
        <%= typeof churchName !== 'undefined' ? churchName : 'HFNI Connect' %>
      </a>
      <div class="flex items-center gap-3">
        <span class="member-name"><%= typeof memberName !== 'undefined' ? memberName : '' %></span>
        <a href="/change-password" class="btn btn-secondary btn-sm desktop-only" data-testid="link-change-password" title="Change Password" style="padding: 0.4rem;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0110 0v4"></path>
          </svg>
        </a>
        <a href="/logout" class="btn btn-primary btn-sm desktop-only" data-testid="button-logout">Logout</a>
      </div>
    </div>
  </div>
  
  <div class="member-content">
    <div class="member-dashboard">
      <% if (typeof message !== 'undefined' && message) { %>
        <div class="alert alert-success mb-4"><%= message %></div>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error mb-4"><%= error %></div>
      <% } %>
      
      <div class="member-welcome">
        <h1>Welcome back<%= typeof memberName !== 'undefined' ? ', ' + memberName.split(' ')[0] : '' %>!</h1>
        <p class="subtitle">What would you like to do today?</p>
      </div>
      
      <!-- TODAY Section -->
      <div class="dashboard-section">
        <div class="dashboard-section-header">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          <h2>Today</h2>
        </div>
        <div class="dashboard-grid">
          <% if (typeof activeMeeting !== 'undefined' && activeMeeting) { %>
          <a href="/checkin" class="dashboard-tile primary" data-testid="tile-checkin">
            <div class="tile-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
            </div>
            <div class="tile-content">
              <h3>Check In</h3>
              <p><%= activeMeeting.title %></p>
            </div>
            <div class="tile-badge live">Live Now</div>
          </a>
          <% } else { %>
          <a href="/checkin" class="dashboard-tile" data-testid="tile-checkin">
            <div class="tile-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
            </div>
            <div class="tile-content">
              <h3>Check In</h3>
              <p>Enter meeting code</p>
            </div>
          </a>
          <% } %>
          
          <a href="/prayer-request" class="dashboard-tile success" data-testid="tile-prayer">
            <div class="tile-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/>
                <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                <line x1="12" x2="12" y1="19" y2="22"/>
              </svg>
            </div>
            <div class="tile-content">
              <h3>Prayer Request</h3>
              <p>Submit a prayer intention</p>
            </div>
          </a>
        </div>
      </div>
      
      <!-- COMMUNITY Section -->
      <div class="dashboard-section">
        <div class="dashboard-section-header">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
          <h2>Community</h2>
        </div>
        <div class="dashboard-grid">
          <a href="/announcements" class="dashboard-tile primary" data-testid="tile-announcements">
            <div class="tile-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
              </svg>
            </div>
            <div class="tile-content">
              <h3>Announcements</h3>
              <p>Church news and updates</p>
            </div>
          </a>
          
          <a href="/notifications" class="dashboard-tile info" data-testid="tile-notifications">
            <div class="tile-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 17H2a3 3 0 0 0 3-3V9a7 7 0 0 1 14 0v5a3 3 0 0 0 3 3zm-8.27 4a2 2 0 0 1-3.46 0"/>
              </svg>
            </div>
            <div class="tile-content">
              <h3>Notifications</h3>
              <p>Reminders and updates</p>
            </div>
          </a>
          
          <a href="/member/messages" class="dashboard-tile success" data-testid="tile-messages">
            <div class="tile-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </div>
            <div class="tile-content">
              <h3>Messages</h3>
              <p>Contact church leadership</p>
            </div>
          </a>
          
          <a href="/groups" class="dashboard-tile secondary" data-testid="tile-groups">
            <div class="tile-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
            <div class="tile-content">
              <h3>My Groups</h3>
              <p>View ministry groups</p>
            </div>
          </a>
        </div>
      </div>
      
      <!-- EVENTS Section -->
      <div class="dashboard-section">
        <div class="dashboard-section-header">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          <h2>Events</h2>
        </div>
        <div class="dashboard-grid">
          <a href="/calendar" class="dashboard-tile warning" data-testid="tile-calendar">
            <div class="tile-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
            </div>
            <div class="tile-content">
              <h3>Calendar</h3>
              <p>View upcoming meetings</p>
            </div>
          </a>
          
          <a href="/rides" class="dashboard-tile info" data-testid="tile-rides">
            <div class="tile-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.5 2.8C1.4 11.3 1 12.1 1 13v3c0 .6.4 1 1 1h2"/>
                <circle cx="7" cy="17" r="2"/>
                <circle cx="17" cy="17" r="2"/>
              </svg>
            </div>
            <div class="tile-content">
              <h3>Carpooling</h3>
              <p>Request or offer rides</p>
            </div>
          </a>
          
          <a href="/volunteer" class="dashboard-tile success" data-testid="tile-volunteer">
            <div class="tile-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <line x1="19" y1="8" x2="19" y2="14"/>
                <line x1="22" y1="11" x2="16" y2="11"/>
              </svg>
            </div>
            <div class="tile-content">
              <h3>Volunteer</h3>
              <p>View opportunities</p>
            </div>
          </a>
          
          <a href="/gallery" class="dashboard-tile secondary" data-testid="tile-gallery">
            <div class="tile-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
            </div>
            <div class="tile-content">
              <h3>Gallery</h3>
              <p>Photos and videos</p>
            </div>
          </a>
          
          <a href="/testimonies" class="dashboard-tile primary" data-testid="tile-testimonies">
            <div class="tile-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </div>
            <div class="tile-content">
              <h3>Testimonies</h3>
              <p>Share and read stories</p>
            </div>
          </a>
        </div>
      </div>
      
      <% if (typeof upcomingEvents !== 'undefined' && upcomingEvents && upcomingEvents.length > 0) { %>
      <div class="dashboard-section">
        <div class="dashboard-section-header">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          <h2>Upcoming Meetings</h2>
        </div>
        <div class="upcoming-events-list">
          <% upcomingEvents.forEach(function(event) { %>
          <div class="upcoming-event-card" data-testid="upcoming-event-<%= event.id %>">
            <div class="event-date">
              <span class="event-day"><%= new Date(event.eventDate).getDate() %></span>
              <span class="event-month"><%= new Date(event.eventDate).toLocaleDateString('en-GB', { month: 'short' }) %></span>
            </div>
            <div class="event-details">
              <h4><%= event.title %></h4>
              <p><%= event.location || 'Location TBA' %></p>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</div>
</body>
</html>
