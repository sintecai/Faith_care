<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= conversation.subject %> - Messages - HFNI Connect</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .message-thread { display: flex; flex-direction: column; gap: 1rem; }
    .message-bubble { padding: 0.75rem 1rem; border-radius: 12px; max-width: 85%; }
    .message-bubble.member { background: var(--primary); color: white; align-self: flex-end; border-bottom-right-radius: 4px; }
    .message-bubble.admin { background: var(--card-bg); border: 1px solid var(--border); align-self: flex-start; border-bottom-left-radius: 4px; }
    .message-meta { font-size: 0.75rem; opacity: 0.7; margin-top: 0.25rem; }
    .reply-form { position: sticky; bottom: 0; background: var(--background); padding: 1rem; border-top: 1px solid var(--border); margin: 0 -1rem -1rem; }
  </style>
</head>
<body>
<div class="member-page hfni-themed">
  <!-- Mobile Navigation -->
  <%- include('../partials/member-mobile-nav') %>
  
  <div class="member-header">
    <div class="member-header-inner">
      <!-- Mobile hamburger button -->
      <button id="mobile-menu-btn" class="mobile-menu-btn" data-testid="button-mobile-menu" aria-label="Open menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
      
      <a href="/member/messages" class="member-logo" data-testid="link-back">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Back
      </a>
      <span class="member-title truncate"><%= conversation.subject %></span>
      <div class="flex items-center gap-3">
        <span class="badge <%= conversation.status === 'open' ? 'badge-success' : 'badge-secondary' %>"><%= conversation.status === 'open' ? 'Open' : 'Closed' %></span>
      </div>
    </div>
  </div>
  
  <div class="member-content">
    <div class="member-dashboard">
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error mb-4"><%= error %></div>
      <% } %>
      
      <div class="message-thread mb-4">
        <% if (typeof messages !== 'undefined' && messages.length > 0) { %>
          <% messages.forEach(function(msg) { %>
            <div class="message-bubble <%= msg.senderType %>" data-testid="message-<%= msg.id %>">
              <div><%= msg.body %></div>
              <div class="message-meta">
                <% if (msg.senderType === 'admin') { %>
                  <strong><%= msg.senderName || 'Church Staff' %></strong> -
                <% } %>
                <%= new Date(msg.createdAt || Date.now()).toLocaleString('en-GB', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %>
              </div>
            </div>
          <% }); %>
        <% } else { %>
          <div class="text-center text-muted py-4">No messages yet.</div>
        <% } %>
      </div>
      
      <% if (conversation.status === 'open') { %>
        <div class="reply-form">
          <form method="POST" action="/member/messages/<%= conversation.id %>/reply" data-testid="form-reply">
            <div class="flex gap-2">
              <textarea name="body" class="form-control flex-1" rows="2" required placeholder="Type your reply..." data-testid="input-reply"></textarea>
              <button type="submit" class="btn btn-primary" data-testid="button-send-reply">Send</button>
            </div>
          </form>
        </div>
      <% } else { %>
        <div class="text-center text-muted py-4">
          This conversation has been closed.
        </div>
      <% } %>
    </div>
  </div>
</div>
</body>
</html>
